# Environment Configuration for Hotel Booking Chatbot
# Copy this file to .env and fill in your actual API keys

# OpenCage Geocoding API
# Get your free key from: https://opencagedata.com/
# This is used to convert city names into geographic coordinates
OPENCAGE_KEY=your-opencage-api-key

# Booking.com API (via RapidAPI)
# Get your key from: https://rapidapi.com/DataCrawler/api/booking-com
# This is used to search for hotels by coordinates
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=booking-com.p.rapidapi.com

# Optional: Set to True for debugging
DEBUG=False
